            "label": "19. Destination Member State(s)",
            "type": "text",
            "required": true
          },
          {
            "id": "number_of_entries",
            "label": "20. Number of Entries Requested",
            "type": "select",
            "required": true,
            "options": [
              {
                "value": "single",
                "label": "Single"
              },
              {
                "value": "double",
                "label": "Double"
              },
              {
                "value": "multiple",
                "label": "Multiple"
              }
            ]
          },
          {
            "id": "duration_of_stay_days",
            "label": "21. Duration of Stay (days)",
            "type": "text",
            "required": true
          },
          {
            "id": "intended_travel_date_from",
            "label": "22. Intended Travel Dates (From)",
            "type": "date",
            "required": true
          },
          {
            "id": "intended_travel_date_to",
            "label": "Intended Travel Dates (To)",
            "type": "date",
            "required": true
          }
        ]
      },
      {
        "id": "support_and_insurance",
        "title": "Support and Insurance",
        "fields": [
          {
            "id": "inviting_person_org_name",
            "label": "23. Inviting Person/Organization (if applicable): Name",
            "type": "text",
            "required": false
          },
          {
            "id": "inviting_person_org_address",
            "label": "Inviting Person/Organization Address",
            "type": "textarea",
            "required": false
          },
          {
            "id": "inviting_person_org_phone",
            "label": "Inviting Person/Organization Phone",
            "type": "text",
            "required": false
          },
