            "type": "textarea",
            "required": true
          }
        ]
      },
      {
        "id": "travel_details",
        "title": "Travel Details",
        "fields": [
          {
            "id": "purpose_of_travel",
            "label": "18. Purpose of Travel",
            "type": "select",
            "required": true,
            "options": [
              {
                "value": "tourism",
                "label": "Tourism"
              },
              {
                "value": "business",
                "label": "Business"
              },
              {
                "value": "family_friends_visit",
                "label": "Family/Friends Visit"
              },
              {
                "value": "medical",
                "label": "Medical"
              },
              {
                "value": "cultural_sports",
                "label": "Cultural/Sports"
              },
              {
                "value": "transit",
                "label": "Transit"
              },
              {
                "value": "other",
                "label": "Other"
              }
