          {
            "id": "surname_family_name",
            "label": "1. Surname (Family Name)",
            "type": "text",
            "required": true
          },
          {
            "id": "surname_at_birth",
            "label": "2. Surname at birth (Former family name)",
            "type": "text",
            "required": false
          },
          {
            "id": "first_names",
            "label": "3. First Name(s)",
            "type": "text",
            "required": true
          },
          {
            "id": "date_of_birth",
            "label": "4. Date of Birth (DD/MM/YYYY)",
            "type": "date",
            "required": true
          },
          {
            "id": "place_of_birth",
            "label": "5. Place of Birth",
            "type": "text",
            "required": true
          },
          {
            "id": "country_of_birth",
            "label": "6. Country of Birth",
            "type": "text",
            "required": true
          },
          {
            "id": "current_nationality",
            "label": "7. Current Nationality",
            "type": "text",
            "required": true
          },
          {
            "id": "sex",
            "label": "8. Sex",
            "type": "select",
            "required": true,
            "options": [
              {
                "value": "male",
                "label": "Male"
              },
              {
                "value": "female",
                "label": "Female"
              },
              {
                "value": "other",
                "label": "Other"
              }
            ]
          },
          {
            "id": "marital_status",
            "label": "9. Marital Status",
            "type": "select",
            "required": true,
            "options": [
              {
                "value": "single",
                "label": "Single"
              },
              {
                "value": "married",
                "label": "Married"
              },
              {
                "value": "divorced",
                "label": "Divorced"
              },
              {
                "value": "widowed",
                "label": "Widowed"
              },
              {
                "value": "other",
                "label": "Other"
              }
            ]
          },
          {
            "id": "fathers_full_name",
            "label": "10. Father's Full Name",
            "type": "text",
            "required": false
          },
          {
            "id": "mothers_full_name",
            "label": "11. Mother's Full Name",
            "type": "text",
            "required": false
          }
        ]
      },
      {
        "id": "contact_and_residence",
        "title": "Contact and Residence Details",
        "fields": [
          {
            "id": "travel_document_type",
            "label": "12. Type of Travel Document",
            "type": "select",
            "required": true,
            "options": [
              {
                "value": "ordinary_passport",
                "label": "Ordinary Passport"
              },
              {
                "value": "diplomatic_passport",
                "label": "Diplomatic Passport"
              },
              {
                "value": "official_passport",
                "label": "Official Passport"
              },
              {
                "value": "other",
                "label": "Other"
              }
            ],
            "conditional_fields": [
              {
                "id": "travel_document_other_text",
                "type": "text",
                "required": true,
                "label": "Specify Other Travel Document",
                "condition": {
                  "field": "travel_document_type",
                  "value": "other"
                }
              }
            ]
          },
          {
            "id": "home_address",
            "label": "13. Applicant’s Home Address",
            "type": "textarea",
            "required": true
          },
          {
            "id": "phone_number",
            "label": "Phone Number",
            "type": "text",
            "required": true
          },
          {
            "id": "email_address",
            "label": "14. Email Address",
            "type": "text",
            "required": true
          },
          {
            "id": "residence_other_than_india",
            "label": "15. Residence in Country Other Than India",
            "type": "boolean",
            "required": true,
            "options": [
              {
                "value": true,
                "label": "Yes"
              },
              {
                "value": false,
                "label": "No"
              }
            ],
            "conditional_fields": [
              {
                "id": "residence_permit_number",
                "type": "text",
                "required": true,
                "label": "Residence permit number",
                "condition": {
                  "field": "residence_other_than_india",
                  "value": true
                }
              },
              {
                "id": "residence_valid_until",
                "type": "date",
                "required": true,
                "label": "Valid until",
                "condition": {
                  "field": "residence_other_than_india",
                  "value": true
                }
              }
            ]
          }
        ]
      },
