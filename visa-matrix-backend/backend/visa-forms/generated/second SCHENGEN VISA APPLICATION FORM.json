              }
            ]
          },
          {
            "id": "means_of_support",
            "label": "25. Means of Support",
            "type": "select",
            "required": true,
            "options": [
              {
                "value": "cash",
                "label": "Cash"
              },
              {
                "value": "credit_card",
                "label": "Credit card"
              },
              {
                "value": "accommodation_provided",
                "label": "Accommodation provided"
              },
              {
                "value": "transport_provided",
                "label": "Transport provided"
              },
              {
                "value": "other",
                "label": "Other"
              }
            ],
            "conditional_fields": [
              {
                "id": "means_of_support_other_text",
                "type": "text",
                "required": true,
                "label": "Specify Other Means of Support",
                "condition": {
                  "field": "means_of_support",
                  "value": "other"
                }
